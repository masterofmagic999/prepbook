DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── AI Provider (optional) ────────────────────────────────────────────────────
# Set AI_PROVIDER to one of: github_models | openrouter | cerebras
# If omitted, the first provider whose key is present is used automatically.
# Leave all keys blank to run in deterministic fallback mode — all features work.
AI_PROVIDER=""

# ── GitHub Models ─────────────────────────────────────────────────────────────
# Get a token at https://github.com/settings/tokens (models:read scope required)
GITHUB_MODELS_TOKEN=""
# GITHUB_MODELS_ENDPOINT="https://models.inference.ai.azure.com"
# GITHUB_MODELS_MODEL="gpt-4o-mini"

# ── OpenRouter (free models available at openrouter.ai) ───────────────────────
# Sign up at https://openrouter.ai and create an API key
OPENROUTER_API_KEY=""
# OPENROUTER_MODEL="meta-llama/llama-3.1-8b-instruct:free"
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# OPENROUTER_SITE_URL="https://your-codespace-url-or-domain"
# OPENROUTER_APP_NAME="PrepBook"

# ── Cerebras Cloud ────────────────────────────────────────────────────────────
# Sign up at https://cloud.cerebras.ai and create an API key
CEREBRAS_API_KEY=""
# CEREBRAS_MODEL="llama3.1-8b"
# CEREBRAS_BASE_URL="https://api.cerebras.ai/v1"
