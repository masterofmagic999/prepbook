DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── GitHub Models AI (optional) ──────────────────────────────────────────────
# Create a GitHub personal access token with `models:read` scope at
# https://github.com/settings/tokens and paste it below to enable AI features:
#   • Enriched per-criterion feedback on DBQ/LEQ submissions
#   (More AI features added over time)
# Leave blank to run in deterministic fallback mode — all features work without it.
GITHUB_MODELS_TOKEN=""

# Override the inference endpoint (default: GitHub Models Azure endpoint)
# GITHUB_MODELS_ENDPOINT="https://models.inference.ai.azure.com"

# Model to use (default: gpt-4o-mini — fast and cost-efficient)
# GITHUB_MODELS_MODEL="gpt-4o-mini"
