DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# GitHub Models — optional AI features
# ---------------------------------------------------------------------------
# In GitHub Codespaces, GITHUB_TOKEN is injected automatically with the
# correct "models:read" scope. No extra steps needed.
#
# For local development:
#   1. Go to https://github.com/settings/tokens and create a fine-grained
#      Personal Access Token (PAT).
#   2. Under "Permissions → Account permissions" enable "GitHub Models" (read).
#   3. Copy the token value below.
#   4. Restart the dev server.
#
# When this variable is absent the app uses deterministic fallback text and
# continues to work normally without any AI features.
GITHUB_TOKEN=""

# Model to use from the GitHub Models catalogue (default: gpt-4o-mini).
# Browse available models at https://github.com/marketplace/models
GITHUB_MODELS_MODEL="gpt-4o-mini"

# Override the inference endpoint only if you are using a custom proxy.
# GITHUB_MODELS_BASE_URL="https://models.inference.ai.azure.com"
