# ─────────────────────────────────────────────────────────────
# PrepBook — environment variable template
# Copy this file to .env.local and fill in your values.
#   cp .env.local.example .env.local
# .env.local is gitignored and should NEVER be committed.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# SQLite (default, zero-config). For Postgres change to:
#   postgresql://user:password@host:5432/dbname
DATABASE_URL="file:./dev.db"

# ── App URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── AI Provider ───────────────────────────────────────────────
# Set to: cerebras | openrouter | github_models | fallback
# Leave blank to auto-detect from whichever key is present.
AI_PROVIDER="cerebras"

# ── Cerebras Cloud ────────────────────────────────────────────
# Sign up at https://cloud.cerebras.ai and copy your API key.
CEREBRAS_API_KEY="your-cerebras-api-key-here"
CEREBRAS_MODEL="llama3.1-8b"
CEREBRAS_BASE_URL="https://api.cerebras.ai/v1"

# ── OpenRouter (free-tier models available) ───────────────────
# Sign up at https://openrouter.ai and create an API key.
OPENROUTER_API_KEY="your-openrouter-api-key-here"
OPENROUTER_MODEL="meta-llama/llama-3.1-8b-instruct:free"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_SITE_URL="http://localhost:3000"
OPENROUTER_APP_NAME="PrepBook"

# ── GitHub Models ─────────────────────────────────────────────
# Requires a GitHub PAT with models:read scope.
GITHUB_MODELS_TOKEN="your-github-pat-here"
GITHUB_MODELS_ENDPOINT="https://models.inference.ai.azure.com"
GITHUB_MODELS_MODEL="gpt-4o-mini"
