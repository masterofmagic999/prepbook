{
  "name": "PrepBook - AP World History",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "features": {},
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "PrepBook Dev Server",
      "onAutoForward": "openPreview"
    }
  },
  "postCreateCommand": "npm install && cp -n .env.local.example .env.local && npx prisma generate && npx prisma db push && npx prisma db seed",
  "postStartCommand": "npm run dev",
  "customizations": {
    "vscode": {
      "extensions": [
        "Prisma.prisma",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  },
  "remoteEnv": {
    "DATABASE_URL": "file:./dev.db"
  }
}
